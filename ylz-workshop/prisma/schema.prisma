generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  role          String
  pin           String
  color         String   @default("#E8681A")
  access        String[]
  canAdvance    Boolean  @default(false)
  canEdit       Boolean  @default(false)
  fullAdmin     Boolean  @default(false)
  defaultScreen String   @default("dashboard")
  section       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Job {
  id        String   @id @default(cuid())
  num       String   @unique
  type      String
  customer  String   @default("")
  stage     String   @default("Fab")
  flag      Boolean  @default(false)
  pairedId  String?
  due       String   @default("")
  btype     String   @default("")
  prodGroup String   @default("issued")
  dealer    String   @default("")
  site      String   @default("")
  sheet     String   @default("")
  dwg       String   @default("")
  mrp       String   @default("")
  parts     String   @default("")
  ebs       String   @default("")
  notes          String   @default("")
  make           String   @default("")
  po             String   @default("")
  dims           String   @default("")
  vin            String   @default("")
  sortOrder      Int      @default(0)
  estimatedHours Float    @default(0)
  startDate      String   @default("")
  customerEmail  String   @default("")
  customerPhone  String   @default("")
  notifyOnAdvance Boolean @default(false)
  bomList        Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Worker {
  id             String      @id
  name           String
  role           String
  section        String
  color          String
  hdr            String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  lastSyncAt     DateTime?
  lastSyncSource String?
  jobs           WorkerJob[]
}

model SyncLog {
  id        String   @id @default(cuid())
  workerId  String
  direction String
  status    String
  detail    String   @default("")
  jobCount  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([workerId])
  @@index([createdAt])
}

model WorkerJob {
  id       String @id @default(cuid())
  workerId String
  jobNo    String
  type     String
  start    String @default("")
  days     Int    @default(1)
  position Int    @default(0)
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model Tarp {
  id    String @id @default(cuid())
  jobNo String
  type  String @default("")
  susp  String @default("pending")
  tyres String @default("pending")
  tarp  String @default("pending")
}

model Timesheet {
  id          String   @id @default(cuid())
  workerName  String
  jobNum      String
  section     String
  workSection String   @default("")
  date        String
  hours       Float
  startTime   String   @default("")
  endTime     String   @default("")
  createdBy   String
  createdAt   DateTime @default(now())
}

model CompletedOrder {
  id     String @id @default(cuid())
  jobNo  String
  name   String
  fab    String @default("")
  paint  String @default("")
  fitout String @default("")
  date   String @default("")
}

model JobNote {
  id         String   @id @default(cuid())
  jobId      String
  authorId   String
  authorName String   @default("")
  type       String
  message    String
  photoUrl   String   @default("")
  photoName  String   @default("")
  createdAt  DateTime @default(now())

  @@index([jobId])
  @@index([type])
}

model JobFile {
  id         String   @id @default(cuid())
  jobId      String
  fileName   String
  fileType   String   @default("")
  filePath   String
  fileSize   Int      @default(0)
  uploadedBy String   @default("")
  createdAt  DateTime @default(now())

  @@index([jobId])
}

model ColdformKit {
  id           String   @id @default(cuid())
  size         String   @default("")
  walls        String   @default("")
  tunnel       String   @default("")
  floor        String   @default("")
  headBoard    String   @default("")
  tailGate     String   @default("")
  splashGuards String   @default("")
  lightStrips  String   @default("")
  allocatedTo  String   @default("")
  notes        String   @default("")
  status       String   @default("")
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ColdformChassis {
  id            String   @id @default(cuid())
  jobNo         String   @default("")
  chassisLength String   @default("")
  dollyType     String   @default("")
  drawbar       String   @default("")
  dateNeeded    String   @default("")
  notes         String   @default("")
  status        String   @default("")
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Delivery {
  id            String   @id @default(cuid())
  jobId         String
  jobNum        String
  customer      String   @default("")
  type          String   @default("")
  invoiceNum    String   @default("")
  invoiceAmount Float    @default(0)
  depositAmount Float    @default(0)
  depositPaid   Boolean  @default(false)
  invoiceSent   Boolean  @default(false)
  paymentStatus String   @default("pending")
  deliveryDate  String   @default("")
  paymentDue    String   @default("")
  paymentDate   String   @default("")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([jobId])
  @@index([paymentStatus])
}

model RepairJob {
  id            String   @id @default(cuid())
  num           String   @unique
  type          String
  description   String   @default("")
  status        String   @default("Open")
  dateReported  String   @default("")
  dateCompleted String   @default("")
  createdBy     String   @default("")
  customerName  String   @default("")
  repairCost    Float    @default(0)
  partsRequired String   @default("")
  bookingDate   String   @default("")
  assignedTo    String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ColdformDelivery {
  id          String   @id @default(cuid())
  date        String
  hardoxJobs  String   @default("")
  chassisJobs String   @default("")
  alloyJobs   String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model JobFollowerCheck {
  id        String    @id @default(cuid())
  jobNum    String
  checkKey  String
  stage     String    @default("")
  checked   Boolean   @default(false)
  checkedBy String    @default("")
  checkedAt DateTime?

  @@unique([jobNum, checkKey])
  @@index([jobNum])
  @@index([stage])
}

model Quote {
  id            String   @id @default(cuid())
  quoteNumber   String   @unique
  status        String   @default("draft")
  customerId    String?
  customerName  String
  dealerName    String   @default("")
  contactName   String   @default("")
  contactEmail  String   @default("")
  contactPhone  String   @default("")
  buildType     String

  configuration Json

  subtotal      Float    @default(0)
  margin        Float    @default(25)
  overhead      Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  overridePrice Float?
  overrideBy    String?
  overrideNote  String?
  declineReason String   @default("")

  preparedBy    String
  salesPerson   String   @default("")
  validDays     Int      @default(30)
  notes         String   @default("")
  terms         String   @default("")

  jobId         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sentAt        DateTime?
  acceptedAt    DateTime?
  expiresAt     DateTime?

  lineItems     QuoteLineItem[]

  @@index([status])
  @@index([customerName])
}

model QuoteLineItem {
  id          String @id @default(cuid())
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  section     String
  description String
  quantity    Int    @default(1)
  unitPrice   Float  @default(0)
  totalPrice  Float  @default(0)
  sortOrder   Int    @default(0)

  @@index([quoteId])
}

model PricingHistory {
  id            String   @id @default(cuid())
  configHash    String
  buildType     String
  configuration Json
  quotedPrice   Float
  quoteNumber   String
  customerName  String
  createdAt     DateTime @default(now())

  @@index([configHash])
  @@index([buildType])
}

model ProductTemplate {
  id            String   @id @default(cuid())
  name          String
  category      String
  description   String   @default("")
  imagePath     String   @default("")
  configuration Json
  basePrice     Float    @default(0)
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([active])
}

// ─── MRPeasy Integration Cache ───────────────────────────────────────────────

model MrpeasyProduct {
  id          String   @id // MRPeasy internal ID
  sku         String   @unique
  name        String
  description String   @default("")
  category    String   @default("") // assembly | component | raw-material
  unitCost    Float    @default(0)
  unit        String   @default("each")
  lastSyncAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bomItems    MrpeasyBomItem[] @relation("BomAssembly")
  usedIn      MrpeasyBomItem[] @relation("BomComponent")

  @@index([category])
  @@index([sku])
}

model MrpeasyBomItem {
  id            String @id @default(cuid())
  assemblyId    String
  componentId   String
  quantity      Float  @default(1)
  unit          String @default("each")

  assembly      MrpeasyProduct @relation("BomAssembly",  fields: [assemblyId],  references: [id])
  component     MrpeasyProduct @relation("BomComponent", fields: [componentId], references: [id])

  @@index([assemblyId])
  @@index([componentId])
}

model MrpeasySyncLog {
  id         String   @id @default(cuid())
  type       String   // products | bom | full
  status     String   // success | failed | partial
  itemCount  Int      @default(0)
  errorMsg   String   @default("")
  syncedAt   DateTime @default(now())

  @@index([syncedAt])
}

// ─── Parts Ordering ───────────────────────────────────────────────────────────

model PartsOrder {
  id           String           @id @default(cuid())
  jobId        String
  jobNum       String           @default("")
  quoteId      String?
  status       String           @default("draft") // draft | sent | partial | complete
  supplier     String           @default("")
  orderDate    String           @default("")
  expectedDate String           @default("")
  notes        String           @default("")
  items        PartsOrderItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([jobId])
  @@index([status])
}

model JobMaster {
  id          String   @id @default(cuid())
  jobNumber   String   @unique
  jobType     String   @default("")
  customer    String   @default("")
  completed   Boolean  @default(false)
  invoiced    String   @default("")
  dimensions  String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobNumber])
}

model JobActivity {
  id        String   @id @default(cuid())
  jobId     String
  userId    String   @default("")
  userName  String   @default("")
  field     String
  fromValue String   @default("")
  toValue   String   @default("")
  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([createdAt])
}

model JobTask {
  id          String    @id @default(cuid())
  jobId       String
  title       String
  assignedTo  String    @default("")
  dueDate     String    @default("")
  completed   Boolean   @default(false)
  completedAt DateTime?
  completedBy String    @default("")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([jobId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  jobId     String    @default("")
  jobNum    String    @default("")
  type      String
  message   String
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model JobDependency {
  id          String   @id @default(cuid())
  jobId       String
  blockedById String
  createdAt   DateTime @default(now())

  @@unique([jobId, blockedById])
  @@index([jobId])
  @@index([blockedById])
}

model PartsOrderItem {
  id          String     @id @default(cuid())
  orderId     String
  partNumber  String     @default("")
  description String
  quantity    Float      @default(1)
  unit        String     @default("each")
  unitCost    Float?
  totalCost   Float?
  status      String     @default("ordered") // ordered | received | backordered
  order       PartsOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Stage-Gated Checklists ───────────────────────────────────────────────────

model ChecklistTemplate {
  id          String   @id @default(cuid())
  stage       String
  label       String
  description String   @default("")
  required    Boolean  @default(true)
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([stage])
  @@index([active])
}

// ─── Digital Delivery Sign-off ────────────────────────────────────────────────

model DeliverySignoff {
  id           String   @id @default(cuid())
  jobId        String
  jobNum       String
  customer     String   @default("")
  signedBy     String
  signerRole   String   @default("customer")
  signatureUrl String
  driverName   String   @default("")
  notes        String   @default("")
  createdAt    DateTime @default(now())

  @@index([jobId])
  @@index([jobNum])
}

// ─── Outbound Customer Messages ───────────────────────────────────────────────

model OutboundMessage {
  id        String   @id @default(cuid())
  jobId     String
  jobNum    String
  channel   String
  recipient String
  subject   String   @default("")
  body      String
  status    String   @default("sent")
  provider  String   @default("")
  error     String   @default("")
  sentAt    DateTime @default(now())

  @@index([jobId])
}

// ─── WHS / Safety Forms ───────────────────────────────────────────────────────

model WhsInjury {
  id                String   @id @default(cuid())
  date              String
  workerName        String
  description       String
  bodyPart          String   @default("")
  treatmentRequired Boolean  @default(false)
  medicalAttention  Boolean  @default(false)
  lostTime          Boolean  @default(false)
  actionTaken       String   @default("")
  reportedBy        String   @default("")
  status            String   @default("open")
  createdAt         DateTime @default(now())

  @@index([date])
  @@index([status])
}

model WhsAudit {
  id              String   @id @default(cuid())
  date            String
  conductedBy     String
  area            String
  findings        String   @default("")
  actionsRequired String   @default("")
  score           Int      @default(0)
  status          String   @default("open")
  createdAt       DateTime @default(now())

  @@index([date])
  @@index([status])
}

model WhsNearMiss {
  id              String   @id @default(cuid())
  date            String
  reportedBy      String
  location        String
  description     String
  potentialInjury String   @default("")
  actionTaken     String   @default("")
  status          String   @default("open")
  createdAt       DateTime @default(now())

  @@index([date])
  @@index([status])
}

model WhsTimeOff {
  id         String   @id @default(cuid())
  workerName String
  startDate  String
  endDate    String   @default("")
  reason     String
  approvedBy String   @default("")
  notes      String   @default("")
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  @@index([workerName])
  @@index([status])
}
